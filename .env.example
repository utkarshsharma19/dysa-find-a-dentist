# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dysa_dental

# API
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
# FastAPI assistant backend (auth + AI booking chat, from whatsupdoc)
NEXT_PUBLIC_WHATSUPDOC_URL=http://localhost:8001/api
# Optional: clinic WhatsApp number for deep-link CTA (digits only, no +)
NEXT_PUBLIC_CLINIC_WA_NUMBER=

# ML inference service (apps/ml, FastAPI + Ultralytics YOLO).
# In production, the web app falls back to the public Hugging Face Space if this is unset.
ML_SERVICE_URL=http://localhost:8000
# Public repo hosting the AGPL-3.0 inference service source (shown on /diagnose)
NEXT_PUBLIC_ML_REPO_URL=https://github.com/utkarshsharma19/-dysa-ml
